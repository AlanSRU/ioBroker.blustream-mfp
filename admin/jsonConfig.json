{
    "i18n": true,
    "type": "panel",
    "items": {
        "_header": {
            "type": "header",
            "text": "Blustream Adapter Configuration",
            "size": 4,
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12
        },
        "deviceModel": {
            "type": "select",
            "label": "Device Model",
            "options": [
                { "value": "amf42au", "label": "AMF42AU (4x2 Advanced Multi-Format)" },
                { "value": "mfp62", "label": "MFP62 (6x2 4K Presentation)" },
                { "value": "mfp72", "label": "MFP72 (4x2 Matrix)" },
                { "value": "mfp112", "label": "MFP112 (5x2 with HDBaseT)" },
                { "value": "wmf51", "label": "WMF51 (Wireless Presenter)" },
                { "value": "wmf72", "label": "WMF72 (Wireless Dual Display)" }
            ],
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "_modelInfoAmf42au": {
            "type": "staticText",
            "text": "AMF42AU: 4 HDMI in / 2 out (HDMI + HDBaseT), 4K@60, picture controls, CEC, mic mixing, 9 presets. Built-in TCP control.",
            "hidden": "data.deviceModel !== 'amf42au'",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "_modelInfoMfp62": {
            "type": "staticText",
            "text": "MFP62: 3 HDMI + DP + USB-C + VGA in, 2 HDMI out with 4K scaler, mic mixing. Built-in TCP control.",
            "hidden": "data.deviceModel !== 'mfp62'",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "_modelInfoMfp72": {
            "type": "staticText",
            "text": "MFP72: 4 HDMI + VGA + AV in, 2 HDMI out with scaler, matrix/splitter mode. RS232 only - use an IP-to-RS232 converter for network control.",
            "hidden": "data.deviceModel !== 'mfp72'",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "_modelInfoMfp112": {
            "type": "staticText",
            "text": "MFP112: 4 HDMI + HDBaseT in, 4 VGA + AV in, 2 HDMI out, HDMI Bypass, IR232 Valens. Built-in TCP control (port 8000).",
            "hidden": "data.deviceModel !== 'mfp112'",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "_modelInfoWmf51": {
            "type": "staticText",
            "text": "WMF51: Wireless presentation, 1 HDMI out (4K), multiview up to 4 windows, WiFi hotspot, dual LAN. Built-in TCP control.",
            "hidden": "data.deviceModel !== 'wmf51'",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "_modelInfoWmf72": {
            "type": "staticText",
            "text": "WMF72: Wireless presentation, 2 HDMI out (4K + 1080p), 11 multiview layouts, audio mixer, PIN/encryption, WiFi, dual LAN, USB host. Built-in TCP control.",
            "hidden": "data.deviceModel !== 'wmf72'",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "connectionType": {
            "type": "select",
            "label": "Connection Type",
            "options": [
                { "value": "ip", "label": "IP (Direct or via RS232-to-IP Converter)" },
                { "value": "serial", "label": "RS232 (Direct Serial Connection)" }
            ],
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "_ipSettingsHeader": {
            "type": "header",
            "text": "IP Connection Settings",
            "size": 5,
            "hidden": "data.connectionType !== 'ip'",
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12
        },
        "ipAddress": {
            "type": "text",
            "label": "IP Address",
            "placeholder": "192.168.1.100",
            "hidden": "data.connectionType !== 'ip'",
            "help": "IP address of the device or RS232-to-IP converter",
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "ipPort": {
            "type": "number",
            "label": "TCP Port",
            "min": 1,
            "max": 65535,
            "hidden": "data.connectionType !== 'ip'",
            "help": "Default: 23 (Telnet)",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "telnetNegotiation": {
            "type": "checkbox",
            "label": "Enable Telnet IAC Negotiation",
            "hidden": "data.connectionType !== 'ip'",
            "help": "Handle Telnet control sequences (recommended for direct device connections)",
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12
        },
        "_serialSettingsHeader": {
            "type": "header",
            "text": "RS232 Connection Settings",
            "size": 5,
            "hidden": "data.connectionType !== 'serial'",
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12
        },
        "serialPort": {
            "type": "text",
            "label": "Serial Port",
            "placeholder": "/dev/ttyUSB0",
            "hidden": "data.connectionType !== 'serial'",
            "help": "e.g. /dev/ttyUSB0 (Linux) or COM3 (Windows)",
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "serialBaudRate": {
            "type": "select",
            "label": "Baud Rate",
            "options": [
                { "value": 9600, "label": "9600" },
                { "value": 19200, "label": "19200" },
                { "value": 38400, "label": "38400" },
                { "value": 57600, "label": "57600" },
                { "value": 115200, "label": "115200" }
            ],
            "hidden": "data.connectionType !== 'serial'",
            "help": "Default for Blustream: 57600",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "_timingHeader": {
            "type": "header",
            "text": "Timing Settings",
            "size": 5,
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12
        },
        "pollingInterval": {
            "type": "number",
            "label": "Polling Interval (ms)",
            "min": 5000,
            "max": 300000,
            "step": 1000,
            "help": "How often to request device status (default: 30000ms)",
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "reconnectInterval": {
            "type": "number",
            "label": "Reconnect Interval (ms)",
            "min": 5000,
            "max": 60000,
            "step": 1000,
            "help": "Time between reconnection attempts (default: 10000ms)",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        }
    }
}
